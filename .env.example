NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Keep the real URI only in .env. Rotate the password that was pasted in chat.
MONGODB_URI=mongodb+srv://<user>:<password>@moneymanager.1k7ypbb.mongodb.net/money-manager?retryWrites=true&w=majority

# Generate with: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret
DATA_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key

# Plaid powers live bank/card connections. Start with sandbox, then move to development/production after Plaid approval.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Optional for production if your frontend is served separately from the API.
# Leave blank in local Vite dev so /api is proxied by vite.config.ts.
VITE_API_BASE=
